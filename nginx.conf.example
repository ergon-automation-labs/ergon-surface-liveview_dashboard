# Example nginx configuration for reverse-proxying multiple LiveView surfaces.
#
# Use this when bundling multiple surfaces (chore + fitness + notifications)
# and want to expose them via a single host port (e.g., 8080).
#
# Copy to nginx.conf and mount in docker-compose.yml:
#   volumes:
#     - ./nginx.conf:/etc/nginx/nginx.conf:ro
#
# Then access:
#   http://localhost:8080/chore
#   http://localhost:8080/fitness
#   http://localhost:8080/notifications

# If running a single surface, you don't need this — just expose the port directly.

upstream chore_surface {
  server web:4001;
}

upstream fitness_surface {
  server web:4002;
}

upstream notifications_surface {
  server web:4003;
}

server {
  listen 8080;
  server_name _;

  # Root path (optional, redirect or show status)
  location = / {
    return 200 "Bot Army Surfaces\n\nAvailable routes:\n/chore\n/fitness\n/notifications\n";
    add_header Content-Type text/plain;
  }

  # Chore surface
  location /chore/ {
    proxy_pass http://chore_surface/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Fitness surface
  location /fitness/ {
    proxy_pass http://fitness_surface/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Notifications surface
  location /notifications/ {
    proxy_pass http://notifications_surface/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Catch-all 404
  location / {
    return 404;
  }
}
